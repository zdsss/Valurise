# Anthropic API Key
ANTHROPIC_API_KEY=your_api_key_here

# API Base URL (optional, for third-party proxy)
# ANTHROPIC_BASE_URL=https://claudecn.top/console

# Model Configuration
MODEL_MAIN=claude-sonnet-4-6
MODEL_FAST=claude-haiku-4-6

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/valurise

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_BASIC=price_basic_id
STRIPE_PRICE_PRO=price_pro_id
STRIPE_PRICE_PREMIUM=price_premium_id

# App
APP_NAME=Valurise
APP_VERSION=1.0.0
DEBUG=True
CORS_ORIGINS=["http://localhost:3000","https://app.valurise.com"]

# Cost Tracking
TARGET_COST_PER_RUN=0.50
